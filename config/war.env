# bar-market-war configuration — single source of truth
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENGINE_DIR="$ROOT/engine-master"   # master CI build (issue #2923 fix; tagged releases are sim-capped headless)
SYSLIBS_DIR="$ROOT/syslibs"
DATA_DIR="$ROOT/data"
# Resolved by install.sh (rapid tag byar:test -> concrete archive name):
GAME_RAPID_TAG="byar:test"
GAME_NAME="Beyond All Reason test-30617-51933b6"
MAP_NAME="Supreme Isthmus v1.8"   # popular symmetric 1v1 map; adjust if download fails
HOST_PORT=8452                    # UDP game host port (expose this for spectators)
FEED_PORT=8642                    # feedd TCP broadcast, localhost only
MUTATOR_HTTP_PORT=8643              # spectators auto-download the current mutator from here
BULLS_TEAM=0
BEARS_TEAM=1
# Tuning: resources granted per 1 SOL/BAM (SOL notional) of taker volume, per side
METAL_PER_BTC=400
ENERGY_PER_BTC=4000
BASELINE_METAL=6                  # per-second floor so neither side starves in a dead market (6 = quiet market can reach T2)
BASELINE_ENERGY=60
LOW_ECO=1                         # 1 = eco structures buildable at 10% output (scale inside config/tweakdefs-low-eco.lua); market income stays primary
AI_DISABLED_UNITS_MID="armsy+corsy+armasy+corasy+armhp+corhp+armfhp+corfhp+armap+corap+armaap+coraap+armplat+corplat+armamsub+coramsub"  # mid lane (SOL): pure ground war — no ship/hover/air/seaplane/amphib labs
AI_DISABLED_UNITS_BAM="armsy+corsy+armasy+corasy+armhp+corhp+armfhp+corfhp+armplat+corplat+armamsub+coramsub"  # BAM lane (teams 6/7): FULL roster minus naval + hover — bot/vehicle/air labs (T1+T2) all allowed; commander free to build anything but ships/hovers
AI_DISABLED_UNITS_FLANK="armlab+corlab+armvp+corvp+armhp+corhp+armfhp+corfhp+armap+corap+armalab+coralab+armavp+coravp+armaap+coraap"  # flank lanes (SP500/GOLD) are naval wars: units come from sea labs only (shipyards, amphib complexes, seaplanes); defences + eco unrestricted
# Rounds (market_rounds.lua): commander death = scored round end, full wipe, fresh spawn
ROUND_INTERMISSION_SEC=10
ROUND_START_METAL=1000
ROUND_START_ENERGY=1000
# Reinforcements (market_reinforce.lua): market events spawn units directly
FLIP_DROP_PCT=0.05                # 1-min move (%) against the dominant side that triggers an underdog drop
FLIP_DROP_HOLD_SEC=30
FLIP_DROP_COOLDOWN_SEC=120
WHALE_SPAWN_BTC=0.5               # 1s taker-volume bucket that deploys units for that side
# Per-lane whale bar (units of the market's native unit) is hardcoded in the PAIRS
# table in market_reinforce.lua: SOL 180, SPX 2, GOLD 4, BAM 20. GOLD is the thinnest
# lane; the fix for its price-decoupled battles is to THICKEN the source feed (more
# gold instruments in feed/feedd.py), not to lower the whale bar (which risks drop-spam).
# Naval scrapper (market_scrapper.lua): clears ocean wrecks in the sea lanes. Gadget
# hardcodes local mirrors of these (war.env is doc source-of-truth, NOT injected).
SCRAP_DROP_PERIOD_SEC=60          # one construction-ship scrapper per sea team per minute
SCRAP_MAX_ALIVE=6                 # live scrappers kept per team (avoid a pileup)
SCRAP_RECLAIM_RADIUS=900          # area-reclaim radius around the team's deep-water point
SCRAP_YIELD=0.10                  # ocean wrecks pay 10% metal (reclaim reduced 90% so scrap is a bonus, not the econ)
SCRAP_SEA_DEPTH=-15              # ground height below this = "ocean" (deep water) for the yield nerf; land lane untouched
# TRUE comeback (MW v12, market_income.lua + market_reinforce.lua): boost the
# side being pushed back RIGHT NOW, keyed to the live army-strength deficit per
# lane (was price momentum, which snowballed the trending side — 68% USD skew
# on the 2026-07-15 overnight run). Boost-only; leading side never docked.
# income mult = 1 + COEF*(e^(deficit/SCALE)-1), deficit=(strong-weak)/(strong+weak) in 0..1
COMEBACK_COEF=1.0                 # boost curve steepness
COMEBACK_SCALE=0.5               # army deficit per e-fold (deficit .5 -> ~2.7x, capped by MAX)
COMEBACK_MAX=4                    # income multiplier ceiling
COMEBACK_MIN_ARMY=1500            # army-value floor before the boost engages (dormant at spawn)
# Comeback reinforcement drops: the losing side gets a squad toward the enemy
COMEBACK_DROP_RATIO=2.0           # strong/weak army ratio that triggers a drop
COMEBACK_DROP_HOLD_SEC=4          # seconds the ratio must hold first
COMEBACK_DROP_COOLDOWN_SEC=45     # per-lane cooldown between comeback drops
# Multi-market lanes (see docs/superpowers/specs/2026-07-12-multi-market-lanes-design.md)
# SPX feed needs Alpaca creds in the ENVIRONMENT (never commit them here):
#   export ALPACA_KEY_ID=... ALPACA_SECRET=...   # free account, IEX websocket
# Without them feedd idles the SPX lane on baseline income.
# Phase-2 streamer (scripts/stream.sh) — STREAM_KEY comes from the ENVIRONMENT, never this file
STREAM_DISPLAY=:99
STREAM_RES=1280x720
STREAM_FPS=30
STREAM_BITRATE=4500k
STREAM_RTMP_URL="rtmp://a.rtmp.youtube.com/live2"
# BAM pump.fun edition (market_pump.lua + market_announce.lua). BAM_MINT empty =>
# feedd proxy mode with --bam-proxy (adopt a live hot mint as a stand-in).
BAM_MINT=""                       # the pump.fun BAM token mint (set once minted)
PUMP_WS_URL="wss://pumpdev.io/ws"  # PumpDev free trade websocket
PUMP_SPAWN_ENABLED=1              # master switch for per-trade spawns
PUMP_MAX_SPAWN_PER_SEC=8          # per BAM team; excess queues
PUMP_QUEUE_CAP=60                 # per BAM team; overflow drops oldest
PUMP_TIER1=0.5                    # solAmount tier cut points -> spawn size/tier
PUMP_TIER2=2
PUMP_TIER3=10
PUMP_TIER4=50
WHALE_SPAWN_SOL=180               # SOL lane whale bar (~$32k, dollar-parity w/ old BTC)
WHALE_SPAWN_BAM=20               # BAM whale bar (SOL notional) — announced banner
BAM_FLIP_PCT=2.0                 # BAM price(marketCapSol) flip threshold (0.05% is memecoin noise)
