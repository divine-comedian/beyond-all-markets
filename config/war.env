# bar-market-war configuration — single source of truth
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
ENGINE_DIR="$ROOT/engine-master"   # master CI build (issue #2923 fix; tagged releases are sim-capped headless)
SYSLIBS_DIR="$ROOT/syslibs"
DATA_DIR="$ROOT/data"
# Resolved by install.sh (rapid tag byar:test -> concrete archive name):
GAME_RAPID_TAG="byar:test"
GAME_NAME="Beyond All Reason test-30617-51933b6"
MAP_NAME="Supreme Isthmus v1.8"   # popular symmetric 1v1 map; adjust if download fails
HOST_PORT=8452                    # UDP game host port (expose this for spectators)
FEED_PORT=8642                    # feedd TCP broadcast, localhost only
MUTATOR_HTTP_PORT=8643              # spectators auto-download the current mutator from here
BULLS_TEAM=0
BEARS_TEAM=1
# Tuning: resources granted per 1 BTC of taker volume, per side
METAL_PER_BTC=400
ENERGY_PER_BTC=4000
BASELINE_METAL=6                  # per-second floor so neither side starves in a dead market (6 = quiet market can reach T2)
BASELINE_ENERGY=60
LOW_ECO=1                         # 1 = eco structures buildable at 10% output (scale inside config/tweakdefs-low-eco.lua); market income stays primary
AI_DISABLED_UNITS_MID="armsy+corsy+armasy+corasy+armhp+corhp+armfhp+corfhp+armap+corap+armaap+coraap+armplat+corplat+armamsub+coramsub"  # mid lane (BTC): pure ground war — no ship/hover/air/seaplane/amphib labs
AI_DISABLED_UNITS_AIR="armlab+corlab+armvp+corvp+armhp+corhp+armfhp+corfhp+armsy+corsy+armasy+corasy+armamsub+coramsub+armalab+coralab+armavp+coravp"  # ETH lane: AIR only — every non-air factory banned
AI_DISABLED_UNITS_FLANK="armlab+corlab+armvp+corvp+armhp+corhp+armfhp+corfhp+armap+corap+armalab+coralab+armavp+coravp+armaap+coraap"  # flank lanes (SP500/GOLD) are naval wars: units come from sea labs only (shipyards, amphib complexes, seaplanes); defences + eco unrestricted
# Rounds (market_rounds.lua): commander death = scored round end, full wipe, fresh spawn
ROUND_INTERMISSION_SEC=10
ROUND_START_METAL=1000
ROUND_START_ENERGY=1000
# Reinforcements (market_reinforce.lua): market events spawn units directly
FLIP_DROP_PCT=0.05                # 1-min move (%) against the dominant side that triggers an underdog drop
FLIP_DROP_HOLD_SEC=30
FLIP_DROP_COOLDOWN_SEC=120
WHALE_SPAWN_BTC=0.5               # 1s taker-volume bucket that deploys units for that side
# Comeback rally (market_income.lua): 5m relative-strength income boost.
# Boost-only — the opposing side is never docked. mult = 1 + 0.5*(e^(gain%/SCALE)-1)
RALLY_WINDOW_SEC=300
RALLY_SCALE_PCT=0.5               # % 5m move per e-fold: 0.25%≈1.3x, 0.5%≈1.9x, 1%≈4.2x
RALLY_MAX=8                       # income multiplier ceiling
# Multi-market lanes (see docs/superpowers/specs/2026-07-12-multi-market-lanes-design.md)
# SPX feed needs Alpaca creds in the ENVIRONMENT (never commit them here):
#   export ALPACA_KEY_ID=... ALPACA_SECRET=...   # free account, IEX websocket
# Without them feedd idles the SPX lane on baseline income.
# Phase-2 streamer (scripts/stream.sh) — STREAM_KEY comes from the ENVIRONMENT, never this file
STREAM_DISPLAY=:99
STREAM_RES=1280x720
STREAM_FPS=30
STREAM_BITRATE=4500k
STREAM_RTMP_URL="rtmp://a.rtmp.youtube.com/live2"
